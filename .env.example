# --- PostgreSQL (Supabase → Database → Connect) ---
# Pro Vercel + Prisma použij „Session pooler“ na portu 5432 jako DATABASE_URL (spolehlivější než transaction 6543).
# DIRECT_URL = stejný host :5432 (pro migrace), nebo „Direct connection“ z dashboardu.
DATABASE_URL="postgresql://postgres.hxsdhfszkvnamgmnuuuc:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.hxsdhfszkvnamgmnuuuc:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
PRISMA_DISABLE_PREPARED_STATEMENTS="true"

# --- Supabase API (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://hxsdhfszkvnamgmnuuuc.supabase.co"
# Publishable / anon — pro @supabase/ssr v prohlížeči; legacy JWT „anon“ klíč taky funguje
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_…"

# GitHub Pages (Vite static-web/) — stejné hodnoty jako NEXT_PUBLIC_*; v CI nastav jako secrets
VITE_SUPABASE_URL="https://TVOJ-PROJEKT.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_…"
# Kořen Next/Vercel app (bez koncového /) — Pages admin po přidání zaměstnance zavolá API a vytvoří Supabase Auth účet
VITE_NEXT_API_ORIGIN="https://TVOJ-PROJEKT.vercel.app"
# Service role — jen server (API routes), nikdy do klienta / gitu
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- App ---
AUTH_SECRET="nahraďte-náhodným-retezcem-openssl-rand-base64-32"
# Produkční URL bez lomítka na konci (Vercel) — jinak může NextAuth dělat redirect smyčky
AUTH_URL="https://TVOJ-PROJEKT.vercel.app"
# Volitelné (CSV): omezí CORS u POST /api/admin/provision-supabase-auth jen na GitHub Pages
# PAGES_ADMIN_ALLOWED_ORIGINS="https://tvuj-uzivatel.github.io"
ADMIN_PASSWORD="silné-heslo-pro-seed"
# Jedno jednoduché heslo pro partu (plain text). Když ho uživatel zadá, bcrypt se neřeší — stačí existující účet admin/jan v DB.
FOX_SHARED_PASSWORD="např-jednoduche-heslo"

# Storage: id bucketu pro účtenky (musí existovat ve Supabase Storage + RLS skript)
# Výchozí v kódu je fakturyauctenky; pro bucket „receipts“ nastav explicitně.
SUPABASE_STORAGE_BUCKET="fakturyauctenky"
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="fakturyauctenky"
VITE_SUPABASE_STORAGE_BUCKET="fakturyauctenky"
