# --- PostgreSQL přes Supabase pooler (IPv4) + přímé připojení pro migrace ---
# V dashboardu: Database → Connect — zkopíruj „Transaction pooler“ / „Session pooler“ a DIRECT_URL.
# Nahraď [PASSWORD], ověř region v hostname (eu-west-1, eu-central-1, …).
DATABASE_URL="postgresql://postgres.hxsdhfszkvnamgmnuuuc:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.hxsdhfszkvnamgmnuuuc:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# --- Supabase API (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://hxsdhfszkvnamgmnuuuc.supabase.co"
# Publishable / anon — pro @supabase/ssr v prohlížeči; legacy JWT „anon“ klíč taky funguje
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_…"
# Service role — jen server (API routes), nikdy do klienta / gitu
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- App ---
AUTH_SECRET="nahraďte-náhodným-retezcem-openssl-rand-base64-32"
