# --- PostgreSQL (Supabase: Project Settings → Database → URI) ---
# Použijte připojení na port 5432 (Session nebo „Direct“). SSL je v řetězci často ?sslmode=require
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Supabase Storage (Project Settings → API) ---
# FOXasistent projekt: https://hxsdhfszkvnamgmnuuuc.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://hxsdhfszkvnamgmnuuuc.supabase.co"
# Service role — jen server, nikdy do klienta / gitu
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- App ---
AUTH_SECRET="nahraďte-náhodným-retezcem-openssl-rand-base64-32"
ADMIN_PASSWORD="silné-heslo-pro-seed"

# Storage: v Supabase vytvořte bucket id „receipts“, zapněte „Public bucket“
